Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Generating", " ", "mock", " ", "data", " ", "for", " ", "good", " ", 
    "predictions"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"forecastedChancesGood", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"5", ",", "95", ",", "5"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"actualWinPercentageGood", "=", 
     RowBox[{"forecastedChancesGood", "+", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
        RowBox[{"Length", "[", "forecastedChancesGood", "]"}]}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"teamCountsGood", "=", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"10", ",", "100"}], "}"}], ",", 
       RowBox[{"Length", "[", "forecastedChancesGood", "]"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Generating", " ", "mock", " ", "data", " ", "for", " ", "bad", " ", 
     "predictions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"forecastedChancesBad", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "95", ",", "5"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"actualWinPercentageBad", "=", 
     RowBox[{"100", "-", "forecastedChancesBad", "+", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
        RowBox[{"Length", "[", "forecastedChancesBad", "]"}]}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"teamCountsBad", "=", 
     RowBox[{"RandomInteger", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"10", ",", "100"}], "}"}], ",", 
       RowBox[{"Length", "[", "forecastedChancesBad", "]"}]}], "]"}]}], ";"}],
    "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Creating", " ", "the", " ", "plot", " ", "for", " ", "good", " ", 
     "predictions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Modify", " ", "existing", " ", "plot", " ", "creation", " ", "code", " ",
      "to", " ", "include", " ", "LabelStyle"}], "*)"}], 
   RowBox[{
    RowBox[{"calibrationPlotGood", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"forecastedChancesGood", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"actualWinPercentageGood", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "forecastedChancesGood", "]"}]}], "}"}]}], 
        "]"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"LightBlue", ",", 
          RowBox[{"PointSize", "[", "Medium", "]"}]}], "]"}]}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "100"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "100"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Forecasted chance of winning\>\"", ",", 
          "\"\<Actual win percentage\>\""}], "}"}]}], ",", 
       RowBox[{"Epilog", "->", 
        RowBox[{"{", 
         RowBox[{"Dashed", ",", 
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"100", ",", "100"}], "}"}]}], "}"}], "]"}]}], "}"}]}], 
       ",", 
       RowBox[{"LabelStyle", "->", 
        RowBox[{"{", 
         RowBox[{"FontSize", "->", "2"}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Creating", " ", "the", " ", "plot", " ", "for", " ", "bad", " ", 
     "predictions"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"calibrationPlotBad", "=", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"forecastedChancesBad", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"actualWinPercentageBad", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "forecastedChancesBad", "]"}]}], "}"}]}], 
        "]"}], ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"Directive", "[", 
         RowBox[{"LightBlue", ",", 
          RowBox[{"PointSize", "[", "Medium", "]"}]}], "]"}]}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "100"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "100"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"AxesLabel", "->", 
        RowBox[{"{", 
         RowBox[{
         "\"\<Forecasted chance of winning\>\"", ",", 
          "\"\<Actual win percentage\>\""}], "}"}]}], ",", 
       RowBox[{"Epilog", "->", 
        RowBox[{"{", 
         RowBox[{"Dashed", ",", 
          RowBox[{"Line", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"100", ",", "100"}], "}"}]}], "}"}], "]"}]}], "}"}]}], 
       ",", 
       RowBox[{"LabelStyle", "->", 
        RowBox[{"{", 
         RowBox[{"FontSize", "->", "2"}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Create", " ", "the", " ", "grid", " ", "of", " ", "plots"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"gridPlots", "=", 
     RowBox[{"Grid", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"\"\<Good Predictions\>\"", ",", "\"\<Bad Predictions\>\""}],
          "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Show", "[", "calibrationPlotGood", "]"}], ",", 
          RowBox[{"Show", "[", "calibrationPlotBad", "]"}]}], "}"}]}], "}"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Export", " ", "the", " ", "grid", " ", "as", " ", "a", " ", "PDF"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<calibration_plots.pdf\>\"", ",", "gridPlots"}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.929798178733103*^9, 3.929798178733103*^9}, {
  3.9297982237169514`*^9, 3.929798233646057*^9}, {3.9297982751521797`*^9, 
  3.9297982915023575`*^9}, {3.929798460296726*^9, 3.9297985009720535`*^9}, {
