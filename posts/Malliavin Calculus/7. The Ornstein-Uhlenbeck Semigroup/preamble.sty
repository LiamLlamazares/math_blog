\ProvidesPackage{preamble}[2025/12/26 v2.0 Consolidated and Refined Setup]

%==============================================================================
% 1. ESSENTIALS & ENCODING
%==============================================================================
\RequirePackage[utf8]{inputenc}             % Input encoding (handles utf8 characters)
\RequirePackage[dvipsnames]{xcolor}         % Color management with strict driver options
                                            % Loaded early to avoid option clashes with other packages

%==============================================================================
% 2. TYPOGRAPHY & TEXT FORMATTING
%==============================================================================

\RequirePackage[relative,overlay]{textpos}
\RequirePackage{microtype}                  % Subliminal refinements towards typographical perfection
                                            % check if compatible with your engine (pdflatex/luatex)

% Disable microtype protrusion in Table of Contents (as per documentation recommendation)
\let\oldtableofcontents\tableofcontents
\renewcommand{\tableofcontents}{%
  \microtypesetup{protrusion=false}%
  \oldtableofcontents%
  \microtypesetup{protrusion=true}%
}

\RequirePackage{csquotes}                   % Context sensitive quotation facilities
\RequirePackage{epigraph}                   % Formatting of epigraphs (quotes at start of chapters)
\RequirePackage{lipsum}                     % Easy access to dummy text (Lorem Ipsum)
\setlength{\marginparwidth}{2cm}    % Fix for todonotes warning
\RequirePackage{todonotes}                  % For TODOs (\td command) - Added based on usage
\RequirePackage{authblk}                    % Support for footnote style author/affiliation blocks
\RequirePackage{multicol}                   % Support for multi-column layout

%==============================================================================
% 3. MATHEMATICS
%==============================================================================
% NOTE: Order matters here to avoid conflicts (e.g., \div)

\RequirePackage{mathtools}                  % Loads amsmath and adds fixes/extensions
\RequirePackage{amssymb}                    % Mathematical symbols (loads amsfonts)

% mathabx provides many symbols but can conflict with physics. 
% Loaded BEFORE physics to allow physics to overwrite or coexist where possible.
\RequirePackage{mathabx}                    

\RequirePackage{physics}                    % Macros for physics (dirac notation \bra\ket, gradients, etc.)
\RequirePackage{bm}                         % Access bold math symbols (\bm{})
\RequirePackage{nicefrac}                   % Compact fractions like 1/2 using \nicefrac
\RequirePackage{dsfont}                     % Double struck font (often used for indicator \mathbb{1})
\RequirePackage{bbm}                        % Alternative double struck font

%==============================================================================
% 4. FIGURES, GRAPHICS & FLOATS
%==============================================================================
\RequirePackage{graphicx}                   % Essential for including images
\graphicspath{{Figures/}}                   % Set default search path for images

\RequirePackage{animate}                    % Support for PDF animations
\RequirePackage{tikz}                       % Powerful procedural drawing package
\RequirePackage{float}                      % Improved interface for floating objects (H option)
\RequirePackage{subcaption}                 % Support for subfigures (replacing obsolete subfig/subfigure)

%==============================================================================
% 5. TABLES & LISTS
%==============================================================================
\RequirePackage{booktabs}                   % Professional quality tables (different rule weights)
\RequirePackage{longtable}                  % Tables that can span multiple pages
\RequirePackage{multirow}                   % Create tabular cells spanning multiple rows
\RequirePackage{enumitem}                   % Control layout of itemize, enumerate, description

%==============================================================================
% 6. MISCELLANEOUS UTILITIES
%==============================================================================
\RequirePackage{fontawesome}                % Access to FontAwesome icons

%==============================================================================
% 7. BIBLIOGRAPHY (Natbib + BibTeX)
%==============================================================================
\RequirePackage[round]{natbib}
\bibliographystyle{apalike}

%==============================================================================
% 8. HYPERLINKS & REFERENCES
%==============================================================================
% hyperref should usually be loaded late, but before cleveref
\RequirePackage{hyperref} 
\hypersetup{
    colorlinks=true,
    linkcolor=RoyalBlue,    % Custom color for internal links
    citecolor=ForestGreen,  % Custom color for citations
    urlcolor=NavyBlue,      % Custom color for URLs
    linktoc=all             % Make both section numbers and titles clickable in ToC
}

%==============================================================================
% 9. THEOREMS & CLEVEREF
%==============================================================================
\RequirePackage{amsthm}                     % Enhanced theorem environments
\RequirePackage{aliascnt}                   % For correct counting of shared theorem counters with cleveref
\RequirePackage[capitalise,noabbrev]{cleveref} % Intelligent cross-referencing (must be loaded last)
                                            % capitalise: "Theorem 1" instead of "theorem 1"
                                            % noabbrev: "Theorem" instead of "Thm."

% --- Cleveref Configuration ---
% Syntax: \crefname{<type>}{<singular>}{<plural>}
% Explains to cleveref how to label the reference. 
% e.g. \cref{thm:1} -> "Theorem 1" (singular) or "Theorems 1 and 2" (plural)

\crefname{theorem}{theorem}{theorems}
\crefname{proposition}{proposition}{propositions}
\crefname{lemma}{lemma}{lemmas}
\crefname{corollary}{corollary}{corollaries}
\crefname{definition}{definition}{definitions}
\crefname{example}{example}{examples}
\crefname{remark}{remark}{remarks}
\crefname{observation}{observation}{observations}
\crefname{assumption}{assumption}{assumptions}

% --- Theorem Definitions ---
\newtheorem{theorem}{Theorem}[section]

% Use aliascnt to share the 'theorem' counter but let cleveref distinguish them
\newaliascnt{proposition}{theorem}
\newtheorem{proposition}[proposition]{Proposition}
\aliascntresetthe{proposition}

\newaliascnt{lemma}{theorem}
\newtheorem{lemma}[lemma]{Lemma}
\aliascntresetthe{lemma}

\newaliascnt{corollary}{theorem}
\newtheorem{corollary}[corollary]{Corollary}
\aliascntresetthe{corollary}

\newaliascnt{definition}{theorem}
\newtheorem{definition}[definition]{Definition}
\aliascntresetthe{definition}

\theoremstyle{definition} % Definition style (non-italic body)
\newaliascnt{example}{theorem}
\newtheorem{example}[example]{Example}
\aliascntresetthe{example}

\newtheorem{observation}{Observation}
\newtheorem{assumption}{Assumption}
\newtheorem{problem}{Problem}
\newtheorem*{problem*}{Problem} % Unnumbered problem
\newtheorem{exercise}{Exercise}
\newtheorem{remark}[theorem]{Remark}
\newtheorem*{hint}{Hint}

\newenvironment{exerciseandhint}[2]
    {\begin{exercise} #1 \par \emph{Hint: #2}}
    {\end{exercise}}

% Blog metadata
\newcommand{\postsubtitle}[1]{}
\newcommand{\posttags}[1]{}  % comma separated
% Cross-post reference: \postref{folder-path}{label}{display text}
% latex2qmd.py resolves this to a relative .qmd link with anchor.
% In pdflatex, degrades to an \href to the live site URL.
\newcommand{\postref}[3]{\href{https://nowheredifferentiable.com/posts/#1/}{#3}}


% Custom Align Environments
\DeclareDocumentEnvironment{aligneq}{ o }{%
    \begin{equation}
    \IfValueT{#1}{\tag{#1}}
    \begin{aligned}
}{%
    \end{aligned}
    \end{equation}
}
\DeclareDocumentEnvironment{aligneq*}{ o }{%
    \begin{equation*}
    \IfValueT{#1}{\tag{#1}}
    \begin{aligned}
}{%
    \end{aligned}
    \end{equation*}
}

\newcommand\summaryname{Abstract}
\newenvironment{Abstract}%
    {\small\begin{center}\bfseries{\summaryname} \end{center}}{}

