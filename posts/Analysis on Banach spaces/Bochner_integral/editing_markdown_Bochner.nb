Cell[TextData[{
 "Markdown gets confused with _, [] and there are extra asterisks and \
environments generated from pandoc in markdown so we change them all. Also \
add equation class and create layout, please ",
 StyleBox["change title, subtitle and tags once file is generated.",
  FontWeight->"Bold"]
}], "Text",
