288334990262"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"startc", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e0", ",", "\"\<[\\\\[\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "1"}], "]"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "the", " ", "place", " ", "citations", " ", 
    "of", " ", "the", " ", 
    RowBox[{"form", " ", "[", 
     RowBox[{"@", "reference"}], "]"}], " ", "start"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stopc0", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e0", ",", "\"\<}\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "all", " ", "the", " ", "places", " ", 
    "citations", " ", "could", " ", "end"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"find2", "[", "x_", "]"}], ":=", 
    RowBox[{"Min", "[", 
     RowBox[{"Select", "[", 
      RowBox[{"stopc0", ",", " ", 
       RowBox[{
        RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "given", " ", "an", " ", "element", " ", 
    "of", " ", "the", " ", "form", " ", "x", " ", "finds", " ", "min", " ", 
    "of", " ", "stopc0", " ", "bigger", " ", "than", " ", "x"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stopc", "=", 
    RowBox[{"Map", "[", 
     RowBox[{"find2", ",", "startc"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "the", " ", "place", " ", "citations", " ", 
    "end"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"replaceme", "=", 
   RowBox[{"Map", "[", 
