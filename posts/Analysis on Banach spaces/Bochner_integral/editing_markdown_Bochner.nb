        RowBox[{
         RowBox[{"\"\<::: example\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: hint\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: exercise\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: proof\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: proposition\>\"", "->", "\"\<\>\""}], ",", 
