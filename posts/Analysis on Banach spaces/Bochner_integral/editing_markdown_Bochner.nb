  3.9255431363305817`*^9}},ExpressionUUID->"165d61c0-f62f-0c4e-a01f-\
af178cf296c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Finding", " ", "the", " ", "reference", " ", "of", " ", "link", " ", 
    "starts"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"middlelinkref", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"StringPosition", "[", 
        RowBox[{"e11", ",", "\"\<(http\>\""}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], ")"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Finding", " ", "all", " ", "the", " ", "places", " ", 
     RowBox[{"references", "[", "text", "]"}], 
     RowBox[{"(", "link", ")"}], " ", "could", " ", "start"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"startlinkref", "=", 
     RowBox[{
      RowBox[{"StringPosition", "[", 
       RowBox[{"e11", ",", "\"\<[\>\""}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"findlink", "[", "x_", "]"}], ":=", 
     RowBox[{"Max", "[", 
      RowBox[{"Select", "[", 
       RowBox[{"startlinkref", ",", 
        RowBox[{
         RowBox[{"#", "<", "x"}], "&"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"startlinkref", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"findlink", ",", "middlelinkref"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Finding", " ", "all", " ", "the", " ", "places", " ", "references", " ", 
     "could", " ", "end"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"stoplinkref", "=", 
     RowBox[{
      RowBox[{"StringPosition", "[", 
       RowBox[{"e11", ",", "\"\<)\>\""}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"findlinkref", "[", "x_", "]"}], ":=", 
     RowBox[{"Min", "[", 
      RowBox[{"Select", "[", 
       RowBox[{"stoplinkref", ",", 
        RowBox[{
         RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stoplinkref", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"findlinkref", ",", "middlelinkref"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Transforming", " ", "links", " ", "to", " ", "HTML"}], "<", "a",
      ">", "tags"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"transformlinkref", "[", "string_", "]"}], ":=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"string", ",", 
       RowBox[{
        RowBox[{
        "RegularExpression", "[", 
         "\"\<\\\\[([^\\\\]]+)\\\\]\\\\(([^\\\\)]+)\\\\)\>\"", "]"}], ":>", 
        "\"\<<a href=\\\"$2\\\">$1</a>\>\""}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Extracting", " ", "and", " ", "transforming", " ", "the", " ", "links"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"transformedlinkref", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"transformlinkref", ",", 
       RowBox[{"StringTake", "[", 
        RowBox[{"e11", ",", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"startlinkref", ",", "stoplinkref"}], "}"}], "]"}]}], 
        "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"e12", "=", 
     RowBox[{"StringReplacePart", "[", 
      RowBox[{"e11", ",", "transformedlinkref", ",", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"startlinkref", ",", "stoplinkref"}], "}"}], "]"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\<blog.txt\>\"", ",", "e12"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
