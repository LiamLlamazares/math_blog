Cell["Now we find the actual url by locating the {}", "Text",
 CellChangeTimes->{{3.862555865235217*^9, 
  3.862555886712981*^9}},ExpressionUUID->"0f88569f-8b35-004c-8bbe-\
ecbd6744ffd7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"lbp", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"bib", ",", "\"\<{\>\""}], "]"}], " ", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"Positions", " ", "of", "  ", 
    RowBox[{"{", " ", 
     RowBox[{"in", " ", "bib", " ", "file"}]}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rbp", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"bib", ",", "\"\<}\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Finds", " ", "positions", " ", "of"}], " ", "}"}], " ", "in", 
    " ", "bib", " ", "file"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"findlb", "[", "x_", "]"}], ":=", 
    RowBox[{"Min", "[", 
     RowBox[{"Select", "[", 
      RowBox[{"lbp", ",", " ", 
       RowBox[{
        RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], " ", ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "given", " ", "an", " ", "element", " ", 
    "of", " ", "the", " ", "form", " ", "x", " ", "finds", " ", "min", " ", 
    "of", " ", "lbp", " ", "bigger", " ", "than", " ", "x"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"findrb", "[", "x_", "]"}], ":=", 
    RowBox[{"Min", "[", 
     RowBox[{"Select", "[", 
      RowBox[{"rbp", ",", " ", 
       RowBox[{
        RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], " ", ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "given", " ", "an", " ", "element", " ", 
    "of", " ", "the", " ", "form", " ", "x", " ", "finds", " ", "min", " ", 
    "of", " ", "rbp", " ", "bigger", " ", "than", " ", "x"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"lbu", "=", 
    RowBox[{"Map", "[", 
     RowBox[{"findlb", ",", "url"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Left", " ", "and", " ", "right", " ", "brackets", " ", "in", " ", "bib"}],
    "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rbu", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"findrb", ",", "url"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"websites", "=", 
   RowBox[{"StringTake", "[", 
    RowBox[{"bib", ",", 
     RowBox[{"Transpose", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"lbu", ",", "rbu"}], "}"}], "+", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"-", "1"}]}], "}"}]}], "]"}]}], "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Gets", " ", "the", " ", "websites", " ", "using", " ", "the", " ", 
    "brackets"}], "*)"}], ";"}]}], "Input",
 CellChangeTimes->{{3.862555894614818*^9, 3.862555995595339*^9}, {
   3.8625560489591*^9, 3.8625561221973853`*^9}, {3.862556191883266*^9, 
