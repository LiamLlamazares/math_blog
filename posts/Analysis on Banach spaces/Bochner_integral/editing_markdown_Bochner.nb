Cell[CellGroupData[{

Cell["Figures", "Section",
 CellChangeTimes->{{3.918038286236193*^9, 
  3.918038291512387*^9}},ExpressionUUID->"8e7713a5-d24b-644d-a222-\
3540bdb82f44"],

Cell["\<\
Input has form ! [alttext](path){label}
Has to be changed to <img \
src=\\\[CloseCurlyDoubleQuote]{{\[OpenCurlyQuote]assets/img/Figures/path\
\[CloseCurlyQuote] | relative_url }}\\\[CloseCurlyDoubleQuote] alt=\\\
\[CloseCurlyDoubleQuote]alt \\\[CloseCurlyDoubleQuote] width=\\\
\[CloseCurlyDoubleQuote]90%\\\[CloseCurlyDoubleQuote] id=\\\
\[CloseCurlyDoubleQuote]label\\\[CloseCurlyDoubleQuote]>\
\>", "Text",
 CellChangeTimes->{{3.918038481460003*^9, 
  3.918038567453354*^9}},ExpressionUUID->"80521836-3066-1047-8402-\
9a069df59eda"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"getimghtml", "[", "string_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"normalizedString", ",", "newpath"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"normalizedString", "=", 
      RowBox[{"StringReplace", "[", 
       RowBox[{"string", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"\"\<\\n\>\"", "->", "\"\< \>\""}], ",", 
          RowBox[{"\"\<\\\\[\>\"", "->", "\"\<[\>\""}], ",", 
          RowBox[{"\"\<\\\\]\>\"", "->", "\"\<]\>\""}]}], "}"}]}], "]"}]}], 
     ";", "\n", 
     RowBox[{"newpath", "=", 
      RowBox[{"StringReplace", "[", 
       RowBox[{"normalizedString", ",", 
        RowBox[{
         RowBox[{"Shortest", "[", 
          RowBox[{
          "\"\<![\>\"", "~~", "description__", "~~", "\"\<]\>\"", "~~", 
           "\"\<(\>\"", "~~", "path__", "~~", "\"\<)\>\"", "~~", "\"\<{\>\"", 
           "~~", "options__", "~~", "\"\<}\>\""}], "]"}], ":>", 
         RowBox[{
         "\"\<<img src=\\\"{{'assets/img/Figures/\>\"", "<>", "path", "<>", 
          "\"\<'| relative_url }}\\\" alt=\\\"\>\"", "<>", 
          RowBox[{"StringReplace", "[", 
           RowBox[{"description", ",", 
            RowBox[{"\"\<$\>\"", "->", "\"\<\>\""}]}], "]"}], "<>", 
          "\"\<\\\" width=\\\"90%\\\" id=\\\"\>\"", "<>", 
          RowBox[{"StringReplace", "[", 
           RowBox[{
            RowBox[{"First", "@", 
             RowBox[{"StringSplit", "[", 
              RowBox[{"options", ",", "\"\< \>\""}], "]"}]}], ",", 
            RowBox[{"\"\<#\>\"", "->", "\"\<\>\""}]}], "]"}], "<>", 
          "\"\<\\\">\>\""}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"newpath", ",", 
       RowBox[{"\"\<.pdf\>\"", "->", "\"\<.svg\>\""}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"figstart", "=", 
   RowBox[{
    RowBox[{"StringPosition", "[", 
     RowBox[{"e01", ",", "\"\<![\>\""}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"figend", "=", " ", 
   RowBox[{
    RowBox[{"StringPosition", "[", 
     RowBox[{"e01", ",", "\"\<}\>\""}], "]"}], "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"findfigend", "[", "x_", "]"}], ":=", 
   RowBox[{"Min", "[", 
    RowBox[{"Select", "[", 
     RowBox[{"figend", ",", " ", 
      RowBox[{
       RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"figendnew", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"findfigend", ",", "figstart"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"transformedfig", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"getimghtml", ",", 
     RowBox[{"StringTake", "[", 
      RowBox[{"e01", ",", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"figstart", ",", "figendnew"}], "}"}], "]"}]}], "]"}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e01", "=", 
   RowBox[{"StringReplacePart", "[", 
    RowBox[{"e01", ",", "transformedfig", ",", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"figstart", ",", "figendnew"}], "}"}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.918038233454998*^9, 3.9180382465057945`*^9}, {
  3.918038306551399*^9, 3.9180383653499107`*^9}, {3.9180397023858795`*^9, 
  3.9180397309245358`*^9}, {3.918040599663055*^9, 3.918040663931143*^9}},
 CellLabel->
  "In[1792]:=",ExpressionUUID->"aa35fe84-ab91-1741-b5b1-20b5d477fcd5"]
}, Open  ]],

