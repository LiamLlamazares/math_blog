          RowBox[{
          "\"\<---\nlayout: post\ntitle: \>\"", "<>", "title", "<>", 
           "\"\<\nsubtitle: \>\"", "<>", "subtitle", "<>", 
           "\"\<\nthumbnail-img: /assets/img/\>\"", "<>", "img", "<>", 
