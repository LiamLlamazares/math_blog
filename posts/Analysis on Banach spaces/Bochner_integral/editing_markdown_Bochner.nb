Cell[BoxData[{
 RowBox[{
  RowBox[{"replaceStar", "[", "s_", "]"}], ":=", 
  RowBox[{"StringReplace", "[", 
   RowBox[{"s", ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<*\>\"", "->", "\"\<\\\\star \>\""}], ",", 
      RowBox[{"\"\<_\>\"", "->", "\"\<\\\\U \>\""}]}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"replaceUnderscore", "[", "s_", "]"}], ":=", 
  RowBox[{"StringReplace", "[", 
   RowBox[{"s", ",", 
    RowBox[{"\"\<_\>\"", "->", "\"\<\\\\U\>\""}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e200", "=", 
   RowBox[{"StringReplace", "[", 
    RowBox[{"e20", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"s", ":", 
         RowBox[{"RegularExpression", "[", "\"\<\\\\$.*?\\\\$\>\"", "]"}]}], ":>", 
        RowBox[{"replaceStar", "[", "s", "]"}]}], ",", 
       RowBox[{
        RowBox[{"s", ":", 
         RowBox[{
         "RegularExpression", "[", 
          "\"\<\\\\\\\\begin\\\\{.*?\\\\}.*?\\\\\\\\end\\\\{.*?\\\\}\>\"", 
          "]"}]}], ":>", 
        RowBox[{"replaceStar", "[", "s", "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"s", ":", 
         RowBox[{"RegularExpression", "[", "\"\<\\\\$$.*?\\\\$$\>\"", "]"}]}],
         ":>", 
        RowBox[{"replaceStar", "[", "s", "]"}]}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"lines", "=", 
   RowBox[{"StringSplit", "[", 
    RowBox[{"e200", ",", "\"\<\\n\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"trimmedLines", "=", 
   RowBox[{"StringTrim", "/@", "lines"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"e21", "=", 
    RowBox[{"StringRiffle", "[", 
     RowBox[{"trimmedLines", ",", "\"\<\\n\>\""}], "]"}]}], ";"}], 
  "\n"}], "\n"}], "Input",
