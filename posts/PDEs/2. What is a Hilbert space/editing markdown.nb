Cell[CellGroupData[{

Cell["Introducing equation labels", "Section",
 CellChangeTimes->{{3.8936113799547024`*^9, 
  3.893611388392294*^9}},ExpressionUUID->"13fb696a-c913-4bd9-84c1-\
f58bc2eae841"],

Cell["\<\
Equation references in pandoc have the form [\\[e2\\]](#e2){reference-type=\
\[CloseCurlyDoubleQuote]eqref\[CloseCurlyDoubleQuote] reference=\
\[CloseCurlyDoubleQuote]e2\[CloseCurlyDoubleQuote]} and have to be changed to \
(\\ref{e2}).\
\>", "Text",
 CellChangeTimes->{{3.893611399546937*^9, 
  3.893611453569108*^9}},ExpressionUUID->"e1eb14db-d697-45e7-b4cb-\
208724129a8d"],

Cell[CellGroupData[{

Cell["First we find the character where citation starts", "Subsection",
 CellChangeTimes->{{3.893611461434867*^9, 
  3.893611481791638*^9}},ExpressionUUID->"b0f95e43-76d8-4484-9e01-\
8bdb4922eafe"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"startc", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e0", ",", "\"\<[\\\\[\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "1"}], "]"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "the", " ", "place", " ", "citations", " ", 
    "of", " ", "the", " ", 
    RowBox[{"form", " ", "[", 
     RowBox[{"@", "reference"}], "]"}], " ", "start"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stopc0", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e0", ",", "\"\<}\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "all", " ", "the", " ", "places", " ", 
    "citations", " ", "could", " ", "end"}], "*)"}]}], "\[IndentingNewLine]", 

 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"find2", "[", "x_", "]"}], ":=", 
    RowBox[{"Min", "[", 
     RowBox[{"Select", "[", 
      RowBox[{"stopc0", ",", " ", 
       RowBox[{
        RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "given", " ", "an", " ", "element", " ", 
    "of", " ", "the", " ", "form", " ", "x", " ", "finds", " ", "min", " ", 
    "of", " ", "stopc0", " ", "bigger", " ", "than", " ", "x"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stopc", "=", 
    RowBox[{"Map", "[", 
     RowBox[{"find2", ",", "startc"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "the", " ", "place", " ", "citations", " ", 
    "end"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"replaceme", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"StringTake", "[", 
       RowBox[{"e0", ",", "#"}], "]"}], "&"}], ",", 
