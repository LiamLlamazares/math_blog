Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"lbp", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"bib", ",", "\"\<{\>\""}], "]"}], " ", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", " ", 
   RowBox[{"Positions", " ", "of", "  ", 
    RowBox[{"{", " ", 
     RowBox[{"in", " ", "bib", " ", "file"}]}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"rbp", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"bib", ",", "\"\<}\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Finds", " ", "positions", " ", "of"}], " ", "}"}], " ", "in", 
    " ", "bib", " ", "file"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"findlb", "[", "x_", "]"}], ":=", 
    RowBox[{"Min", "[", 
     RowBox[{"Select", "[", 
      RowBox[{"lbp", ",", " ", 
       RowBox[{
        RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], " ", ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "given", " ", "an", " ", "element", " ", 
    "of", " ", "the", " ", "form", " ", "x", " ", "finds", " ", "min", " ", 
    "of", " ", "lbp", " ", "bigger", " ", "than", " ", "x"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"findrb", "[", "x_", "]"}], ":=", 
    RowBox[{"Min", "[", 
     RowBox[{"Select", "[", 
      RowBox[{"rbp", ",", " ", 
       RowBox[{
        RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], " ", ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "given", " ", "an", " ", "element", " ", 
    "of", " ", "the", " ", "form", " ", "x", " ", "finds", " ", "min", " ", 
