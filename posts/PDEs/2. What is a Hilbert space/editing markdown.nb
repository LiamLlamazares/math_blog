Cell["\<\
Citations that are added to document will be of the form [1](url) so they can \
be clicked on. The zzx zzy  will be changed to [] once the other [] are \
changed.\
\>", "Text",
 CellChangeTimes->{{3.8625571040141473`*^9, 3.8625571381078105`*^9}, {
  3.862557194013817*^9, 
  3.862557217814159*^9}},ExpressionUUID->"4865f689-3b3d-4a93-85e5-\
3214ea93ae2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"citn", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"StringJoin", "[", 
      RowBox[{"\"\<zzx\>\"", ",", 
       RowBox[{"ToString", "[", "i", "]"}], ",", "\"\<zzy\>\"", ",", 
       "\"\<(\>\"", ",", 
       RowBox[{"websites", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", "\"\<)\>\""}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"Length", "[", "websites", "]"}]}], "}"}]}], "]"}]}], " ", 
  ";"}]], "Input",
 CellChangeTimes->{{3.862556794339066*^9, 3.862556952209484*^9}, {
   3.862556992236782*^9, 3.862557003375809*^9}, {3.8625570722919645`*^9, 
   3.8625570972661233`*^9}, 3.862557142646863*^9},
