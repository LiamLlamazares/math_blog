         RowBox[{"\"\<::: proof\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: proposition\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: lemma\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: example\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: theorem\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: corollary\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<::: definition\>\"", "->", "\"\<\>\""}], ",", " ", 
         RowBox[{"\"\<:::\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{"\"\<^*\>\"", "->", "\"\<^\\\\star \>\""}], ",", 
         RowBox[{"\"\<**\>\"", "->", "\"\<zzz\>\""}], ",", 
         RowBox[{"\"\<*\>\"", "->", "\"\<\>\""}], ",", 
         RowBox[{
          RowBox[{"\"\<---\>\"", "~~", 
           RowBox[{"Shortest", "[", "___", "]"}], "~~", "\"\<---\>\""}], "->", 
          RowBox[{
          "\"\<---\nlayout: post\ntitle: \>\"", "<>", "title", "<>", 
