  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "all", " ", "the", " ", "places", " ", "labels",
     " ", "could", " ", "end"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"findtm", "[", "x_", "]"}], ":=", 
    RowBox[{"Min", "[", 
     RowBox[{"Select", "[", 
