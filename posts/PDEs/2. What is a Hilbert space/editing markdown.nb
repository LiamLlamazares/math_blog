Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bibp", "=", 
    RowBox[{
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"StringPosition", "[", 
           RowBox[{"bib", ",", "#"}], "]"}], "&"}], ",", 
