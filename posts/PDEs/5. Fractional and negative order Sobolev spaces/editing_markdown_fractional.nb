       RowBox[{"e02", ",", "\"\<{reference-type\>\""}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}], " ", ")"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
