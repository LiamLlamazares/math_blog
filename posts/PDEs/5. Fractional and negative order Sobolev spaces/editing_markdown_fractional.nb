Cell["\<\
First we find all the citation is the markdown file in text form generated \
through pandoc. Assuming citations are of the form [@reference]\
\>", "Text",
 CellChangeTimes->{{3.862554722828952*^9, 
  3.862554761767479*^9}},ExpressionUUID->"e76dc3e8-9704-4d45-b0be-\
9ee2ff00fddb"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"stc", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e", ",", "\"\<[@\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "the", " ", "place", " ", "citations", " ", 
    "of", " ", "the", " ", 
    RowBox[{"form", " ", "[", 
     RowBox[{"@", "reference"}], "]"}], " ", "start"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stpe", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e", ",", "\"\<]\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "all", " ", "the", " ", "places", " ", 
    "citations", " ", "could", " ", "end"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"find", "[", "x_", "]"}], ":=", 
    RowBox[{"Min", "[", 
     RowBox[{"Select", "[", 
      RowBox[{"stpe", ",", " ", 
       RowBox[{
        RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "given", " ", "an", " ", "element", " ", 
    "of", " ", "the", " ", "form", " ", "x", " ", "finds", " ", "min", " ", 
    "of", " ", "stpe", " ", "bigger", " ", "than", " ", "x"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ste", "=", 
    RowBox[{"Map", "[", 
     RowBox[{"find", ",", "stc"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "the", " ", "place", " ", "citations", " ", 
    "of", " ", "the", " ", 
    RowBox[{"form", " ", "[", 
     RowBox[{"@", "reference"}], "]"}], " ", "start"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"StringTake", "[", 
      RowBox[{"e", ",", "#"}], "]"}], "&"}], ",", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"stc", ",", "ste"}], "}"}], "]"}]}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{"This", " ", "obtains", " ", "all", " ", "the", " ", "full", " ", 
    RowBox[{"references", " ", "[", 
     RowBox[{"@", "reference"}], "]"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"citations", "=", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"StringTake", "[", 
        RowBox[{"e", ",", 
         RowBox[{"#", "+", 
          RowBox[{"{", 
           RowBox[{"2", ",", 
            RowBox[{"-", "1"}]}], "}"}]}]}], "]"}], "&"}], ",", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"stc", ",", "ste"}], "}"}], "]"}]}], "]"}]}], "  ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "obtains", " ", "all", " ", "the", " ", "full", " ", 
    "references", " ", "reference"}], "*)"}], " "}], "\[IndentingNewLine]", 
 RowBox[{"citationsformatted", "=", 
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"StringJoin", "[", 
      RowBox[{
       RowBox[{"Capitalize", "[", 
        RowBox[{
         RowBox[{"StringCases", "[", 
          RowBox[{"#", ",", 
           RowBox[{"LetterCharacter", ".."}]}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", "\"\<, \>\"", ",", 
       RowBox[{
        RowBox[{"StringCases", "[", 
         RowBox[{"#", ",", 
          RowBox[{"DigitCharacter", ".."}]}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "&"}], ",", "citations"}], 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.86255281516675*^9, 3.862552846031124*^9}, {
