 RowBox[{
  RowBox[{
   RowBox[{"starttmref", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e02", ",", "\"\<[\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"This", " ", "finds", " ", "all", " ", "the", " ", "places", " ", 
    RowBox[{"referencess", " ", "[", "13", "]"}], 
    RowBox[{"(", 
     RowBox[{"#negative", " ", "s", " ", "Slobodeckij"}], ")"}], 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"reference", "-", "type"}], "=."}], ".."}], " ", "could", " ",
       "start"}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"findtmlink", "[", "x_", "]"}], ":=", 
   RowBox[{"Max", "[", 
    RowBox[{"Select", "[", 
     RowBox[{"starttmref", ",", " ", 
      RowBox[{
       RowBox[{"#", "<", "x"}], "&"}]}], "]"}], "]"}]}], 
  " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"starttmref", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"findtmlink", ",", "middletmref"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stoptmref", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e02", ",", "\"\<}\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "all", " ", "the", " ", "places", " ", 
    "referencess", " ", "could", " ", "end"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"findtmref", "[", "x_", "]"}], ":=", 
   RowBox[{"Min", "[", 
    RowBox[{"Select", "[", 
     RowBox[{"stoptmref", ",", " ", 
      RowBox[{
       RowBox[{"#", ">", "x"}], "&"}]}], "]"}], "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "Function", " ", "that", " ", "given", " ", "an", " ", "element", " ", 
    "of", " ", "the", " ", "form", " ", "x", " ", "finds", " ", "min", " ", 
    "of", " ", "stopc0tm", " ", "bigger", " ", "than", " ", "x"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stoptmref", "=", 
    RowBox[{"Map", "[", 
     RowBox[{"findtmref", ",", "middletmref"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{"This", " ", "finds", " ", "the", " ", "labels", "  ", "end"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"transformthmref", "[", "string_", "]"}], ":=", 
  RowBox[{"StringReplace", "[", 
   RowBox[{"string", ",", 
    RowBox[{
     RowBox[{"\"\<[\>\"", "~~", 
      RowBox[{"num", ":", 
       RowBox[{"DigitCharacter", ".."}]}], "~~", "\"\<]\>\"", "~~", 
      "\"\<(\>\"", "~~", 
      RowBox[{"link", ":", 
       RowBox[{
        RowBox[{"Except", "[", "\"\<)\>\"", "]"}], ".."}]}], "~~", 
      "\"\<)\>\"", "~~", "\"\<{\>\"", "~~", 
      RowBox[{"Shortest", "[", 
       RowBox[{"\"\<reference-type=\\\"ref\\\"\>\"", "~~", 
        RowBox[{"WhitespaceCharacter", ".."}]}], "]"}], "~~", 
      "\"\<reference=\\\"\>\"", "~~", 
      RowBox[{"link2", ":", 
       RowBox[{
        RowBox[{"Except", "[", "\"\<\\\"\>\"", "]"}], ".."}]}], "~~", 
      "\"\<\\\"\>\"", "~~", "\"\<}\>\""}], ":>", 
     RowBox[{
     "\"\<<a href=\\\"\>\"", "~~", "link", "~~", "\"\<\\\">\>\"", "~~", "num",
       "~~", "\"\<</a>\>\""}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"transformedthmref", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"transformthmref", ",", 
     RowBox[{"StringTake", "[", 
      RowBox[{"e02", ",", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"starttmref", ",", "stoptmref"}], "}"}], "]"}]}], "]"}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e03", "=", 
   RowBox[{"StringReplacePart", "[", 
    RowBox[{"e02", ",", "transformedthmref", ",", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"starttmref", ",", "stoptmref"}], "}"}], "]"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.894470703585167*^9, 3.894470836603606*^9}, {
