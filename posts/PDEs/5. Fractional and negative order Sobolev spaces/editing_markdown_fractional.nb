      RowBox[{"findlinkref", ",", "middlelinkref"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Transforming", " ", "links", " ", "to", " ", "HTML"}], "<", "a",
      ">", "tags"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"transformlinkref", "[", "string_", "]"}], ":=", 
     RowBox[{"StringReplace", "[", 
      RowBox[{"string", ",", 
       RowBox[{
        RowBox[{
        "RegularExpression", "[", 
         "\"\<\\\\[([^\\\\]]+)\\\\]\\\\(([^\\\\)]+)\\\\)\>\"", "]"}], ":>", 
        "\"\<<a href=\\\"$2\\\">$1</a>\>\""}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Extracting", " ", "and", " ", "transforming", " ", "the", " ", "links"}],
     "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"transformedlinkref", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"transformlinkref", ",", 
       RowBox[{"StringTake", "[", 
        RowBox[{"e11", ",", 
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"startlinkref", ",", "stoplinkref"}], "}"}], "]"}]}], 
        "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"e12", "=", 
     RowBox[{"StringReplacePart", "[", 
      RowBox[{"e11", ",", "transformedlinkref", ",", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"startlinkref", ",", "stoplinkref"}], "}"}], "]"}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"\"\<blog.txt\>\"", ",", "e11"}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Export", "[", 
     RowBox[{"postpath", ",", "e11", ",", "\"\<Text\>\""}], "]"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Uploaded", " ", "to", " ", "github"}], "*)"}]}]}]], "Input",
