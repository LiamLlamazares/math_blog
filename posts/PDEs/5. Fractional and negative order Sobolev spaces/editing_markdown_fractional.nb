Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Finding", " ", "the", " ", "reference", " ", "of", " ", "link", " ", 
    "starts"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"middlelinkref", "=", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"StringPosition", "[", 
        RowBox[{"e11", ",", "\"\<(http\>\""}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], ")"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Finding", " ", "all", " ", "the", " ", "places", " ", 
     RowBox[{"references", "[", "text", "]"}], 
     RowBox[{"(", "link", ")"}], " ", "could", " ", "start"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"startlinkref", "=", 
     RowBox[{
      RowBox[{"StringPosition", "[", 
       RowBox[{"e11", ",", "\"\<[\>\""}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"findlink", "[", "x_", "]"}], ":=", 
     RowBox[{"Max", "[", 
      RowBox[{"Select", "[", 
       RowBox[{"startlinkref", ",", 
        RowBox[{
         RowBox[{"#", "<", "x"}], "&"}]}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"startlinkref", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"findlink", ",", "middlelinkref"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Finding", " ", "all", " ", "the", " ", "places", " ", "references", " ", 
     "could", " ", "end"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"stoplinkref", "=", 
     RowBox[{
      RowBox[{"StringPosition", "[", 
       RowBox[{"e11", ",", "\"\<)\>\""}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"findlinkref", "[", "x_", "]"}], ":=", 
