Cell[TextData[{
 "Another option is to use https://pandoc.org/try/ \n",
 StyleBox["If link contains parenthesis will do error. Find portion of text \
far from parenthesis. Check links that don\[CloseCurlyQuote]t work with ctrl \
f [ on webpage",
  FontWeight->"Bold"],
 "\nAligned wont be cited but align will. Indentation can also be important \
notebook will do it automatically thanks to Pandoc.\n",
 StyleBox["Can\[CloseCurlyQuote]t label sections",
  FontWeight->"Bold"],
 "\nExcessive bracketing {{{p \\U k^\\star}_\\gamma}}... can give errors"
}], "Text",
