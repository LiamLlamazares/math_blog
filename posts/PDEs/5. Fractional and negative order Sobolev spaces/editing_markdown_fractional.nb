Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"asterisks", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e01", ",", "\"\<**\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"has", " ", 
    RowBox[{"form", " ", "**", " ", "Theorem"}], " ", 
    RowBox[{"1", "**", " ", "so"}], " ", "we", " ", "look", " ", "four", " ", 
    "double", " ", "asterisks"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"findtmend", "[", "x_", "]"}], ":=", 
  RowBox[{"Max", "[", 
   RowBox[{"Select", "[", 
    RowBox[{"asterisks", ",", " ", 
     RowBox[{
      RowBox[{"#", ">", "x"}], "&"}], ",", "2"}], "]"}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tmend", "=", 
   RowBox[{"Map", "[", 
    RowBox[{"findtmend", ",", "stoptm"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fulltm", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"StringTake", "[", 
       RowBox[{"e01", ",", "#"}], "]"}], "&"}], ",", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"startctm", ",", "tmend"}], "}"}], "]"}]}], "]"}]}], " ", ";", 
  RowBox[{"fulltmwithend", "=", 
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"StringReplacePart", "[", 
       RowBox[{"#", ",", "\"\<** </a> \>\"", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "2"}], ",", 
          RowBox[{"-", "1"}]}], "}"}]}], "]"}], "&"}], ",", "fulltm"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nameend", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"StringPosition", "[", 
       RowBox[{"replacemetm", ",", "\"\<.\>\"", ",", "2"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "1", ",", "1"}], "]"}], "]"}], "-", "2"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "position", " ", "adter", " ", "which", " ", "the", " ", "theorem", " ", 
    "name", " ", "starts"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nametm", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"StringTake", "[", 
      RowBox[{
       RowBox[{"replacemetm", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"3", ",", 
         RowBox[{"nameend", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], "}"}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", 
       RowBox[{"Length", "[", "nameend", "]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"goodtm", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"StringReplace", "[", 
       RowBox[{
        RowBox[{"fulltmwithend", "[", 
         RowBox[{"[", "i", "]"}], "]"}], ",", 
        RowBox[{
         RowBox[{"replacemetm", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "->", 
         RowBox[{"\"\<<a name=\\\"\>\"", "<>", 
          RowBox[{"nametm", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "<>", "\"\<\\\"> \>\""}]}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "nameend", "]"}]}], "}"}]}], "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"Text", " ", "that", " ", "we", " ", "want"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tmrule", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"fulltm", "[", 
        RowBox[{"[", "i", "]"}], "]"}], "->", 
       RowBox[{"goodtm", "[", 
        RowBox[{"[", "i", "]"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "replacemetm", "]"}]}], "}"}]}], "]"}]}], 
   ";"}], 
  RowBox[{"(*", 
   RowBox[{"Replacement", " ", "rule"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"e02", "=", 
    RowBox[{"StringReplace", "[", 
     RowBox[{"e01", ",", "tmrule"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "post", " ", "with", " ", "theorems", " ", "properly", " ", "labeled"}], 
   "*)"}]}]}], "Input",
