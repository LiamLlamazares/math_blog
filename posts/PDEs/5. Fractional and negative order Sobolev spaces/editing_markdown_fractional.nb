    RowBox[{"{", 
     RowBox[{
      RowBox[{"\"\<*\>\"", "->", "\"\<\\\\star \>\""}], ",", 
      RowBox[{"\"\<_\>\"", "->", "\"\<\\\\U \>\""}]}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
