Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"stc1", "=", 
    RowBox[{
     RowBox[{"StringPosition", "[", 
      RowBox[{"e00", ",", "\"\<\\\\label\>\""}], "]"}], "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "1"}], "]"}], "]"}]}], " ", ";"}], 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "the", " ", "place", " ", "citations", " ", 
    "of", " ", "the", " ", "form", " ", "\\\\", "label", " ", "start"}], 
