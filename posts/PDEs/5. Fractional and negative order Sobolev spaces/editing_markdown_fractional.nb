   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"stopc1", "=", 
    RowBox[{"Map", "[", 
     RowBox[{"find21", ",", "stc1"}], "]"}]}], ";"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "finds", " ", "the", " ", "place", " ", "citations", " ", 
