    RowBox[{"\"\<_\>\"", "->", "\"\<\\\\U\>\""}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"e200", "=", 
   RowBox[{"StringReplace", "[", 
