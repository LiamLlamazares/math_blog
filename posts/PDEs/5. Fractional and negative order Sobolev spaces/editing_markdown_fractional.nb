   "This", " ", "finds", " ", "all", " ", "the", " ", "aligned", " ", 
    "ends"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"find21", "[", "x_", "]"}], ":=", 
