<div class="quarto-listing quarto-listing-container-custom">
<div class="dashboard-container">
<div class="dashboard-top">

<div class="pane featured-pane">
<h3 class="pane-label math-font">Latest Post</h3>
<a href="<%- featured.path %>" class="featured-link">
<% if (featured.image) { %>
<div class="featured-image" style="background-image: url('<%- featured.image %>');"></div>
<% } %>
<h2 class="math-font"><%- featured.title %></h2>
<p class="excerpt"><%- featured.description || featured.subtitle || '' %></p>

<div class="featured-actions">
<span class="read-more">Read more &rarr;</span>
<% if (featured.pdf) { %>
<object data="<%- getPdfPath(featured) %>" type="application/pdf" style="display:none;"></object>
<span href="<%- getPdfPath(featured) %>" class="pdf-download-link" onclick="event.preventDefault(); window.open('<%- getPdfPath(featured) %>');">
  <img src="https://img.icons8.com/material-outlined/24/000000/pdf.png" style="height: 16px; vertical-align: middle; margin-right: 4px; filter: opacity(0.6);"/>
  PDF Version
</span>
<% } %>
</div>
</a>
</div>

<div class="pane recent-list-pane">
<h3 class="pane-label math-font">Most recent posts </h3>
<ul>
<% for (const post of recent) { %>
<li>
  <a href="<%- post.path %>"><%- post.title %></a>, <span class="date"><%- post.date %></span>
  <% if (post.pdf) { %>
    <span onclick="event.preventDefault(); window.open('<%- getPdfPath(post) %>');" class="recent-pdf-link" title="Download PDF">
      [PDF]
    </span>
  <% } %>
</li>
<% } %>
</ul>
</div>

</div>

<div class="dashboard-grid">
<% 
  const sortedTags = Object.keys(tags).sort();
  for (let t = 0; t < sortedTags.length; t++) {
    const tag = sortedTags[t];
    const tagPosts = tags[tag];
    const bannerImg = getBannerImage(tag);
    if (tagPosts.length > 1) { 
%>
<div class="pane tag-pane">
<div class="tag-header" style="<%- bannerImg ? `background-image: url('/${bannerImg}') !important;` : '' %>">
<h3 class="math-font"><%- tag %></h3>
<span class="count"><%- tagPosts.length %> <img src="/assets/img/svgs/leaf.svg" alt="leaf" class="leaf-icon"></span>
</div>
<div class="pane-content">
<ul class="tag-post-list">
<% for (let i = 0; i < Math.min(3, tagPosts.length); i++) { %>
<li><a href="<%- tagPosts[i].path %>"><%- tagPosts[i].title %></a></li>
<% } %>
</ul>
<a href="/index.html#category=<%- encodeURIComponent(tag) %>" class="pane-footer">Explore Topic &rarr;</a>
</div>
</div>
<% } } %>
</div>
</div>
