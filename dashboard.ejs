<%
if (items.length > 0) {
  const featured = items[0];
  const recent = items.slice(1, 5);

  // Standardize the covers mapping
  const covers = {
    'stochastic calculus': 'assets/img/Collection_covers/cover_SC.jpg',
    'pdes': 'assets/img/Collection_covers/cover_PDE.jpg',
    'pde': 'assets/img/Collection_covers/cover_PDE.jpg',
    'malliavin calculus': 'assets/img/Collection_covers/cover_MC.jpg',
    'analysis on banach spaces': 'assets/img/Collection_covers/cover_MC.jpg'
  };

  // Build normalized tags map to avoid duplicates (e.g., "Pdes" vs "PDEs")
  const tags = {};
  for (const item of items) {
    if (item.categories) {
      for (let rawCat of item.categories) {
        const cat = rawCat.trim();
        const normKey = cat.toLowerCase();
        
        // Find existing tag or use the first one encountered (to preserve display name)
        let groupName = cat;
        // Search if we already have this normalized key
        const existingKey = Object.keys(tags).find(k => k.toLowerCase() === normKey);
        if (existingKey) {
          groupName = existingKey;
        }

        if (!tags[groupName]) tags[groupName] = [];
        tags[groupName].push(item);
      }
    }
  }

  const getBannerImage = (catName) => {
    const key = String(catName).toLowerCase().trim();
    return covers[key] || null;
  };

  const getPdfPath = (post) => {
    if (!post.pdf) return null;
    return post.path.replace(/\/[^\/]*$/, '') + '/' + post.pdf;
  };
%>

